---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import MainNav from '../components/MainNav.astro';
import { SITE_DESCRIPTION, SITE_TITLE, EMAIL } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		day: '2-digit',
		month: 'short',
	}).toUpperCase().replace(',', '');
}

const postsByYear = posts.reduce((acc, post) => {
	const year = post.data.pubDate.getFullYear();
	if (!acc[year]) acc[year] = [];
	acc[year].push(post);
	return acc;
}, {} as Record<number, typeof posts>);

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="wrapper">
			<MainNav />

			<!-- HERO SECTION -->
			<header class="hero">
				<div class="hero-info">
					<h1 class="glitch-hover">KUBA<br>SZWAJKA</h1>
					<p class="hero-description">
						Software engineer based in Wroclaw. I build things for early-stage startups and write about what I learn along the way.
					</p>
				</div>
			</header>

			<!-- BLOG ENTRIES -->
			<main class="content-area">
				<h2 class="section-label">01. LOGS</h2>

				{years.map((year) => (
					<section class="year-group">
						<h3 class="year-label">{year}</h3>
						{postsByYear[Number(year)].map((post) => (
							<a href={`/blog/${post.id}/`} class="entry">
								<span class="entry-date">{formatDate(post.data.pubDate)}</span>
								<span class="entry-title">{post.data.title}</span>
							</a>
						))}
					</section>
				))}
			</main>

			<Footer />
		</div>
	</body>
</html>

<style>
	/* --- HERO SECTION --- */
	.hero {
		padding: 3rem 2rem;
	}

	@media (min-width: 900px) {
		.hero {
			padding: 4rem;
		}
	}

	.hero-info h1 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.5rem;
		font-weight: 700;
		line-height: 1;
		text-transform: uppercase;
		margin-bottom: 1rem;
		letter-spacing: -1px;
		color: var(--accent);
	}

	.hero-description {
		font-size: 1rem;
		color: var(--text-dim);
		margin-bottom: 1rem;
		max-width: 550px;
		line-height: 1.7;
	}


	/* --- CONTENT AREA --- */
	.content-area {
		padding: 2rem;
	}

	@media (min-width: 900px) {
		.content-area {
			padding: 2rem 4rem;
		}
	}

	/* --- BLOG ENTRIES --- */
	.entry {
		display: flex;
		gap: 1.5rem;
		padding: 0.6rem 0;
		border-bottom: 1px solid var(--border-color);
		text-decoration: none;
		color: var(--text-main);
		transition: color 0.15s;
	}

	.entry:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.entry-date {
		font-size: 0.8rem;
		color: var(--text-dim);
		flex-shrink: 0;
		width: 7rem;
	}

	.entry-title {
		font-size: 0.95rem;
	}

	.year-group {
		margin-bottom: 2rem;
	}

	.year-label {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 0.85rem;
		color: var(--text-dim);
		margin-bottom: 0.5rem;
	}
</style>
