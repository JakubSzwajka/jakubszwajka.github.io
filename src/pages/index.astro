---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MainNav from '../components/MainNav.astro';
import { SITE_DESCRIPTION, SITE_TITLE, EMAIL } from '../consts';
import { getCollection } from 'astro:content';

// Get all blog posts sorted by date (newest first)
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 15);

// Format date for display
function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		day: '2-digit',
		month: 'short',
		year: 'numeric'
	}).toUpperCase().replace(',', '');
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="wrapper">
			<!-- HERO SECTION -->
			<header class="hero">
				<div class="hero-info">
					<h1 class="glitch-hover">KUBA<br>SZWAJKA</h1>
					<p class="hero-description">
						Software engineer based in Wroclaw. I build things for early-stage startups and write about what I learn along the way.
					</p>
				</div>
			</header>

			<!-- MAIN NAVIGATION -->
			<MainNav />

			<!-- NAV STRIP -->
			<Header />

			<!-- BLOG ENTRIES -->
			<main class="content-area">
				<h2 class="section-label">01. LOGS</h2>

				{posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="entry">
						<span class="entry-date">{formatDate(post.data.pubDate)}</span>
						<span class="entry-title">{post.data.title}</span>
					</a>
				))}

				<div class="view-all">
					<a href="/blog" class="btn-arrow">View All Posts -&gt;</a>
				</div>
			</main>

			<Footer />
		</div>
	</body>
</html>

<style>
	/* --- HERO SECTION --- */
	.hero {
		border-bottom: 2px solid var(--text-main);
		padding: 4rem 2rem;
	}

	@media (min-width: 900px) {
		.hero {
			padding: 6rem 4rem;
		}
	}

	.hero-info h1 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.5rem;
		font-weight: 700;
		line-height: 1;
		text-transform: uppercase;
		margin-bottom: 1rem;
		letter-spacing: -1px;
		color: var(--accent);
	}

	.hero-description {
		font-size: 1rem;
		color: var(--text-dim);
		margin-bottom: 1rem;
		max-width: 550px;
		line-height: 1.7;
	}


	/* --- CONTENT AREA --- */
	.content-area {
		padding: 2rem;
	}

	@media (min-width: 900px) {
		.content-area {
			padding: 2rem 4rem;
		}
	}

	/* --- BLOG ENTRIES --- */
	.entry {
		display: flex;
		gap: 1.5rem;
		padding: 0.6rem 0;
		border-bottom: 1px solid var(--border-color);
		text-decoration: none;
		color: var(--text-main);
		transition: color 0.15s;
	}

	.entry:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.entry-date {
		font-size: 0.8rem;
		color: var(--text-dim);
		flex-shrink: 0;
		width: 7rem;
	}

	.entry-title {
		font-size: 0.95rem;
	}

	.view-all {
		margin-top: 1.5rem;
	}

	.view-all a {
		color: var(--text-dim);
		text-decoration: none;
		font-size: 0.85rem;
	}

	.view-all a:hover {
		color: var(--accent);
	}
</style>
