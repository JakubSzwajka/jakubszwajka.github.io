---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import MainNav from '../components/MainNav.astro';
import { SITE_DESCRIPTION, SITE_TITLE, EMAIL } from '../consts';
import { labArtifacts } from '../data/labArtifacts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		day: '2-digit',
		month: 'short',
	}).toUpperCase().replace(',', '');
}

const postsByYear = posts.reduce((acc, post) => {
	const year = post.data.pubDate.getFullYear();
	if (!acc[year]) acc[year] = [];
	acc[year].push(post);
	return acc;
}, {} as Record<number, typeof posts>);

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="lab-page home-page">
			<MainNav />

			<header class="home-hero">
				<div class="lab-shell home-hero__inner">
					<div class="hero-copy">
						<p class="lab-eyebrow">Public Technical Lab</p>
						<h1>Notes, projects, and traces from software work.</h1>
						<p>
							I use this place as an index for things I am trying to understand or ship:
							architecture notes, AI workflows, product experiments, and build logs.
						</p>
					</div>
					<aside class="site-ledger" aria-label="Site summary">
						<div class="ledger-row"><span>notes</span><b>{posts.length} public artifacts</b></div>
						<div class="ledger-row"><span>projects</span><b>{labArtifacts.length} current objects</b></div>
						<div class="ledger-row"><span>focus</span><b>systems / AI / product</b></div>
					</aside>
				</div>
			</header>

			<main class="lab-shell home-main">
				<section aria-labelledby="projects-title" class="home-section">
					<div class="section-title">
						<h2 id="projects-title">Projects</h2>
						<p>Current objects on the bench. Exposed enough to show direction, not inflated into case-study theater.</p>
					</div>
					<div class="artifact-list">
						{labArtifacts.map((item, index) => (
							<a class="artifact-row" href={item.link} target="_blank" rel="noopener noreferrer">
								<span class="artifact-meta">
									<span class="lab-label">artifact / {String(index + 1).padStart(3, '0')}</span>
									<span>{item.status}</span>
								</span>
								<strong class="artifact-title">{item.title}</strong>
								<span class="artifact-desc">{item.description}</span>
								<span class="stack" aria-label={`${item.title} stack`}>
									{item.tags.map((tag) => (
										<span class="lab-chip">{tag}</span>
									))}
								</span>
							</a>
						))}
					</div>
				</section>

				<section id="archive" class="archive-section" aria-labelledby="archive-title">
					<div class="section-title">
						<h2 id="archive-title">Archive</h2>
						<p>All public notes remain available from this index.</p>
					</div>
					<div class="archive-grid">
						{years.map((year) => (
							<section class="year-group" aria-labelledby={`archive-${year}`}>
								<h3 id={`archive-${year}`}>{year}</h3>
								{postsByYear[Number(year)].map((post) => (
									<a href={`/blog/${post.id}/`} class="archive-row">
										<span>{formatDate(post.data.pubDate)}</span>
										<b>{post.data.title}</b>
										{post.data.aiSlop && <span class="ai-slop-badge">AI SLOP</span>}
									</a>
								))}
							</section>
						))}
					</div>
				</section>
			</main>

			<Footer />
		</div>
	</body>
</html>

<style>
	.home-hero {
		min-height: 46vh;
		display: grid;
		align-items: end;
		border-bottom: 1px solid var(--border-color);
	}

	.home-hero__inner {
		display: grid;
		grid-template-columns: minmax(0, 820px) minmax(260px, 1fr);
		gap: 4.5rem;
		align-items: end;
		padding: 4.5rem 0 3.25rem;
	}

	.hero-copy h1 {
		font-size: 5.1rem;
		line-height: 0.95;
		letter-spacing: 0;
		margin: 1.1rem 0 0;
		max-width: 920px;
	}

	.hero-copy p:not(.lab-eyebrow) {
		color: var(--text-dim);
		font-size: 0.96rem;
		line-height: 1.75;
		margin: 1.5rem 0 0;
		max-width: 720px;
	}

	.site-ledger {
		justify-self: end;
		width: min(100%, 360px);
		border-left: 1px solid var(--border-color);
		padding-left: 1.6rem;
	}

	.ledger-row {
		display: grid;
		grid-template-columns: 5.5rem 1fr;
		gap: 1rem;
		border-bottom: 1px solid var(--border-color);
		padding: 0.72rem 0;
		font-size: 0.75rem;
	}

	.ledger-row span {
		color: var(--text-dim);
		text-transform: uppercase;
	}

	.ledger-row b {
		color: var(--text-main);
		font-weight: 400;
	}

	.home-main {
		padding: 2.6rem 0 5rem;
	}

	.home-section {
		margin-bottom: 3.4rem;
	}

	.section-title {
		display: grid;
		grid-template-columns: 180px minmax(0, 1fr);
		gap: 1.5rem;
		align-items: baseline;
		margin-bottom: 1.1rem;
	}

	.section-title h2,
	.sidebox h2 {
		font-size: 0.82rem;
		letter-spacing: 0;
		text-transform: uppercase;
		margin: 0;
	}

	.section-title p,
	.sidebox p {
		color: var(--text-dim);
		font-size: 0.82rem;
		margin: 0;
	}

	.artifact-row {
		display: grid;
		grid-template-columns: 180px minmax(220px, 0.85fr) minmax(0, 1.4fr) auto;
		gap: 1.5rem;
		align-items: start;
		padding: 1.5rem 0;
		color: var(--text-main);
		text-decoration: none;
		transition: color 0.15s;
	}

	.artifact-row + .artifact-row {
		border-top: 1px solid var(--border-color);
	}

	.artifact-row:hover,
	.artifact-row:focus-visible {
		color: var(--accent);
		text-decoration: none;
	}

	.artifact-meta {
		display: grid;
		gap: 0.35rem;
		color: var(--text-dim);
		font-size: 0.7rem;
		text-transform: uppercase;
	}

	.artifact-title {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 2.5rem;
		line-height: 1;
		font-weight: 700;
	}

	.artifact-desc {
		color: var(--text-dim);
		font-size: 0.82rem;
		line-height: 1.65;
		max-width: 620px;
	}

	.stack {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.4rem;
	}

	.sidebox {
		border-top: 1px solid var(--border-color);
		margin: 0 0 3.4rem auto;
		max-width: 320px;
		padding-top: 1.1rem;
	}

	.sidebox h2 {
		margin-bottom: 1rem;
	}

	.sidebox p {
		line-height: 1.65;
		margin-bottom: 1rem;
	}

	.side-link {
		display: block;
		border-bottom: 1px solid var(--border-color);
		color: var(--text-main);
		font-size: 0.82rem;
		padding: 0.66rem 0;
		text-decoration: none;
	}

	.side-link:hover,
	.side-link:focus-visible {
		color: var(--accent);
		text-decoration: none;
	}

	.archive-section {
		padding-top: 2.4rem;
	}

	.archive-grid {
		column-count: 2;
		column-gap: 4.5rem;
		column-rule: 1px solid var(--border-color);
	}

	.year-group {
		break-inside: avoid;
		margin-bottom: 2.1rem;
	}

	.year-group h3 {
		color: var(--text-dim);
		font-size: 0.82rem;
		margin: 0 0 0.6rem;
	}

	.archive-row {
		display: grid;
		grid-template-columns: 6rem minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: baseline;
		color: var(--text-main);
		font-size: 0.82rem;
		padding: 0.5rem 0;
		text-decoration: none;
	}

	.ai-slop-badge {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--accent);
		border: 1px solid var(--accent);
		background: transparent;
		padding: 0.18rem 0.4rem;
		line-height: 1;
		white-space: nowrap;
	}

	.archive-row:hover,
	.archive-row:focus-visible {
		color: var(--accent);
		text-decoration: none;
	}

	.archive-row span {
		color: var(--text-dim);
		text-transform: uppercase;
	}

	.archive-row b {
		font-weight: 400;
	}

	@media (max-width: 1100px) {
		.home-hero__inner {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.hero-copy h1 {
			font-size: 4rem;
		}

		.site-ledger {
			justify-self: start;
			width: 100%;
			border-left: 0;
			border-top: 1px solid var(--border-color);
			padding: 1.1rem 0 0;
		}

		.artifact-row {
			grid-template-columns: 1fr;
			gap: 0.55rem;
		}

		.stack {
			justify-content: flex-start;
		}

		.sidebox {
			margin-left: 0;
			max-width: none;
		}
	}

	@media (max-width: 720px) {
		.home-hero__inner {
			padding: 3.5rem 0 2.6rem;
		}

		.hero-copy h1 {
			font-size: 2.75rem;
		}

		.section-title,
		.archive-grid {
			display: block;
		}

		.archive-grid {
			column-count: auto;
			column-gap: 0;
			column-rule: 0;
		}

		.section-title p {
			margin-top: 0.5rem;
		}

		.artifact-title {
			font-size: 2rem;
		}

		.year-group {
			margin-bottom: 1.8rem;
		}

		.archive-row {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}
	}
</style>
