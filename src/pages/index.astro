---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import MainNav from '../components/MainNav.astro';
import { SITE_DESCRIPTION, SITE_TITLE, EMAIL } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		day: '2-digit',
		month: 'short',
	}).toUpperCase().replace(',', '');
}

const postsByYear = posts.reduce((acc, post) => {
	const year = post.data.pubDate.getFullYear();
	if (!acc[year]) acc[year] = [];
	acc[year].push(post);
	return acc;
}, {} as Record<number, typeof posts>);

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="wrapper">
			<MainNav />

			<!-- HERO SECTION -->
			<header class="hero">
				<div class="hero-info">
					<p class="eyebrow">PUBLIC TECHNICAL LAB</p>
					<h1 class="glitch-hover">KUBA SZWAJKA</h1>
					<p class="hero-description">
						Notes, experiments, build logs, and software thoughts from the things I am trying to understand or ship.
					</p>
					<p class="hero-description">
						Expect rough edges, changing opinions, and useful traces from the workbench.
					</p>
				</div>
			</header>

			<!-- BLOG ENTRIES -->
			<main class="content-area" aria-label="Writing archive">
				<div class="content-header">
					<h2>Lab notes</h2>
					<p>{posts.length} public artifacts, newest first.</p>
				</div>
				{years.map((year) => (
					<section class="year-group">
						<h3 class="year-label">{year}</h3>
						{postsByYear[Number(year)].map((post) => (
							<a href={`/blog/${post.id}/`} class="entry">
								<span class="entry-date">{formatDate(post.data.pubDate)}</span>
								<span class="entry-title">{post.data.title}</span>
							</a>
						))}
					</section>
				))}
			</main>

			<Footer />
		</div>
	</body>
</html>

<style>
	/* --- HERO SECTION --- */
	.hero {
		padding: 3rem 2rem;
	}

	@media (min-width: 900px) {
		.hero {
			padding: 4rem;
		}
	}

	.eyebrow {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--text-dim);
		margin-bottom: 0.5rem;
	}

	.hero-info h1 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: clamp(2.25rem, 8vw, 5.5rem);
		font-weight: 700;
		line-height: 0.9;
		text-transform: uppercase;
		margin-bottom: 1.5rem;
		letter-spacing: -0.06em;
		color: var(--accent);
	}

	.hero-description {
		max-width: 760px;
		font-size: 1rem;
		color: var(--text-dim);
		margin-bottom: 1rem;
		line-height: 1.7;
	}


	/* --- CONTENT AREA --- */
	.content-area {
		padding: 2rem;
	}

	@media (min-width: 900px) {
		.content-area {
			padding: 2rem 4rem;
		}
	}

	.content-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		padding-bottom: 0.75rem;
		margin-bottom: 1.5rem;
		border-bottom: 1px solid var(--border-color);
	}

	.content-header h2 {
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		margin: 0;
	}

	.content-header p {
		font-size: 0.8rem;
		color: var(--text-dim);
		margin: 0;
	}

	/* --- BLOG ENTRIES --- */
	.entry {
		display: flex;
		gap: 1.5rem;
		padding: 0.6rem 0;
		border-bottom: 1px solid var(--border-color);
		text-decoration: none;
		color: var(--text-main);
		transition: color 0.15s;
	}

	.entry:hover,
	.entry:focus-visible {
		color: var(--accent);
		text-decoration: none;
	}

	.entry-date {
		font-size: 0.8rem;
		color: var(--text-dim);
		flex-shrink: 0;
		width: 7rem;
	}

	.entry-title {
		font-size: 0.95rem;
	}

	.year-group {
		margin-bottom: 2rem;
	}

	.year-label {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 0.85rem;
		color: var(--text-dim);
		margin-bottom: 0.5rem;
	}

	@media (max-width: 600px) {
		.content-header {
			align-items: flex-start;
			flex-direction: column;
		}

		.entry {
			gap: 0.75rem;
			flex-direction: column;
		}

		.entry-date {
			width: auto;
		}
	}
</style>
