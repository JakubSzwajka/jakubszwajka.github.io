---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import MainNav from '../components/MainNav.astro';
import { SITE_TITLE } from '../consts';
import { labArtifacts } from '../data/labArtifacts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Projects // ${SITE_TITLE}`}
			description="Lab artifacts and shipped experiments by Kuba Szwajka"
		/>
	</head>
	<body>
		<div class="lab-page projects-page">
			<MainNav />

			<main class="lab-shell projects-main">
				<header class="page-head">
					<p class="lab-eyebrow">Lab artifacts</p>
					<div>
						<h1>Projects</h1>
						<p>
							Things shipped, tested, or used as a workbench. A little more room here for screenshots,
							context, and where each artifact stands now.
						</p>
					</div>
				</header>

				<section class="project-list" aria-label="Project artifacts">
					{labArtifacts.map((item, index) => (
						<article class="project-row">
							<div class="artifact-meta">
								<span class="lab-label">artifact / {String(index + 1).padStart(3, '0')}</span>
								<span>{item.status}</span>
							</div>
							<h2>
								<a href={item.link} target="_blank" rel="noopener noreferrer">{item.title}</a>
							</h2>
							<p class="project-desc">{item.description}</p>
							<div class="stack" aria-label={`${item.title} stack`}>
								{item.tags.map((tag) => (
									<span class="lab-chip">{tag}</span>
								))}
							</div>

							<div class="screen-strip">
								{item.screenshots.length > 0 ? (
									<div class="carousel" data-carousel={`carousel-${item.id}`}>
										<div class="carousel-inner">
											{item.screenshots.map((screenshot, screenshotIndex) => (
												<img
													src={screenshot}
													alt={`${item.title} screenshot ${screenshotIndex + 1}`}
													class={`carousel-image ${screenshotIndex === 0 ? 'active' : ''}`}
													loading={screenshotIndex === 0 ? 'eager' : 'lazy'}
												/>
											))}
										</div>
										{item.screenshots.length > 1 && (
											<div class="carousel-dots" aria-label={`${item.title} screenshots`}>
												{item.screenshots.map((_, screenshotIndex) => (
													<button
														class={`carousel-dot ${screenshotIndex === 0 ? 'active' : ''}`}
														data-index={screenshotIndex}
														aria-label={`View ${item.title} screenshot ${screenshotIndex + 1}`}
														aria-pressed={screenshotIndex === 0 ? 'true' : 'false'}
													></button>
												))}
											</div>
										)}
									</div>
								) : (
									<div class="screen-placeholder">// {item.title}</div>
								)}
							</div>
						</article>
					))}
				</section>
			</main>

			<Footer />
		</div>

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const carousels = document.querySelectorAll('.carousel');
				carousels.forEach((carousel) => {
					const images = carousel.querySelectorAll('.carousel-image');
					const dots = carousel.querySelectorAll('.carousel-dot');
					if (images.length <= 1) return;
					let currentIndex = 0;
					dots.forEach((dot, index) => {
						dot.addEventListener('click', () => {
							images[currentIndex].classList.remove('active');
							dots[currentIndex].classList.remove('active');
							dots[currentIndex].setAttribute('aria-pressed', 'false');
							currentIndex = index;
							images[currentIndex].classList.add('active');
							dots[currentIndex].classList.add('active');
							dots[currentIndex].setAttribute('aria-pressed', 'true');
						});
					});
				});
			});
		</script>
	</body>
</html>

<style>
	.projects-main {
		padding: 3.5rem 0 5.2rem;
	}

	.page-head {
		display: grid;
		grid-template-columns: 180px minmax(0, 860px);
		gap: 2rem;
		align-items: end;
		margin-bottom: 2.9rem;
	}

	.page-head h1 {
		font-size: 5.4rem;
		line-height: 0.95;
		letter-spacing: 0;
		margin: 0;
	}

	.page-head p:not(.lab-eyebrow) {
		color: var(--text-dim);
		font-size: 0.9rem;
		line-height: 1.7;
		margin: 1rem 0 0;
		max-width: 760px;
	}

	.project-list {
		border-top: 1px solid var(--border-color);
	}

	.project-row {
		display: grid;
		grid-template-columns: 150px minmax(260px, 0.75fr) minmax(0, 1fr) 220px;
		gap: 1.5rem;
		align-items: start;
		padding: 1.9rem 0;
		border-bottom: 1px solid var(--border-color);
	}

	.artifact-meta {
		display: grid;
		gap: 0.35rem;
		color: var(--text-dim);
		font-size: 0.7rem;
		text-transform: uppercase;
	}

	.project-row h2 {
		font-size: 3.35rem;
		line-height: 0.95;
		letter-spacing: 0;
		margin: 0;
	}

	.project-row h2 a {
		color: var(--text-main);
		text-decoration: none;
	}

	.project-row h2 a:hover,
	.project-row h2 a:focus-visible {
		color: var(--accent);
		text-decoration: none;
	}

	.project-desc {
		color: var(--text-dim);
		font-size: 0.82rem;
		line-height: 1.7;
		margin: 0;
		max-width: 620px;
	}

	.stack {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.4rem;
	}

	.screen-strip {
		grid-column: 2 / 5;
		height: 230px;
		border: 1px solid var(--border-color);
		background: color-mix(in srgb, var(--bg-panel) 48%, transparent);
		margin-top: 0.4rem;
		overflow: hidden;
		position: relative;
	}

	.carousel,
	.carousel-inner {
		position: relative;
		width: 100%;
		height: 100%;
	}

	.carousel-image {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center;
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 0.25s ease;
		background: var(--bg-panel);
	}

	.carousel-image.active {
		opacity: 1;
		position: relative;
	}

	.carousel-dots {
		position: absolute;
		bottom: 0.75rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0.5rem;
		padding: 0.4rem;
		background: color-mix(in srgb, var(--bg-color) 82%, transparent);
		border: 1px solid var(--border-color);
	}

	.carousel-dot {
		width: 10px;
		height: 10px;
		border: 1px solid var(--text-dim);
		background: transparent;
		cursor: pointer;
		padding: 0;
	}

	.carousel-dot.active {
		background: var(--accent);
		border-color: var(--accent);
	}

	.screen-placeholder {
		display: grid;
		place-items: center;
		height: 100%;
		color: var(--text-dim);
		font-size: 0.8rem;
	}

	@media (max-width: 1100px) {
		.page-head,
		.project-row {
			grid-template-columns: 1fr;
		}

		.page-head h1 {
			font-size: 4rem;
		}

		.project-row {
			gap: 0.75rem;
		}

		.project-row h2 {
			font-size: 2.7rem;
		}

		.stack {
			justify-content: flex-start;
		}

		.screen-strip {
			grid-column: auto;
		}
	}

	@media (max-width: 700px) {
		.projects-main {
			padding: 3rem 0 4rem;
		}

		.page-head h1 {
			font-size: 2.85rem;
		}

		.project-row h2 {
			font-size: 2.2rem;
		}

		.screen-strip {
			height: 190px;
		}
	}
</style>
