---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import MainNav from '../components/MainNav.astro';
import { SITE_TITLE } from '../consts';

const portfolioItems = [
	{
		id: 1,
		title: 'MyDanceDNA',
		description: 'Directory platform for dancers — search schools, instructors, and courses by style, location, or price.',
		link: 'https://www.mydancedna.com',
		image: '/projects/mydancedna/hero.png',
		screenshots: [
			'/projects/mydancedna/hero.png',
			'/projects/mydancedna/Xnapper-2025-12-28-16.45.33.png',
			'/projects/mydancedna/Xnapper-2025-12-28-16.45.53.png'
		],
		tags: ['PYTHON', 'FASTAPI', 'REACT', 'POSTGRESQL']
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Projects // ${SITE_TITLE}`}
			description="Selected projects by Kuba Szwajka"
		/>
	</head>
	<body>
		<div class="wrapper">
			<MainNav />

			<main class="content-area">
				{portfolioItems.map((item) => (
					<article class="project">
						<div class="project-image-container">
							{item.screenshots && item.screenshots.length > 0 ? (
								<div class="carousel" data-carousel={`carousel-${item.id}`}>
									<div class="carousel-inner">
										{item.screenshots.map((screenshot, index) => (
											<img
												src={screenshot}
												alt={`${item.title} screenshot ${index + 1}`}
												class={`carousel-image ${index === 0 ? 'active' : ''}`}
											/>
										))}
									</div>
									{item.screenshots.length > 1 && (
										<div class="carousel-dots">
											{item.screenshots.map((_, index) => (
												<button
													class={`carousel-dot ${index === 0 ? 'active' : ''}`}
													data-index={index}
													aria-label={`View screenshot ${index + 1}`}
												></button>
											))}
										</div>
									)}
								</div>
							) : (
								<img src={item.image} alt={item.title} class="project-image" />
							)}
						</div>

						<div class="project-info">
							<h3>
								{item.link ? (
									<a href={item.link} target="_blank">{item.title} →</a>
								) : (
									item.title
								)}
							</h3>
							<p>{item.description}</p>
							<div class="tags">
								{item.tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
						</div>
					</article>
				))}
			</main>

			<Footer />
		</div>

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const carousels = document.querySelectorAll('.carousel');
				carousels.forEach((carousel) => {
					const images = carousel.querySelectorAll('.carousel-image');
					const dots = carousel.querySelectorAll('.carousel-dot');
					if (images.length <= 1) return;
					let currentIndex = 0;
					dots.forEach((dot, index) => {
						dot.addEventListener('click', () => {
							images[currentIndex].classList.remove('active');
							dots[currentIndex].classList.remove('active');
							currentIndex = index;
							images[currentIndex].classList.add('active');
							dots[currentIndex].classList.add('active');
						});
					});
				});
			});
		</script>
	</body>
</html>

<style>
	.content-area {
		padding: 2rem;
		max-width: 800px;
		margin: 0 auto;
	}

	.project {
		margin-bottom: 3rem;
	}

	.project-image-container {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		margin-bottom: 1rem;
	}

	.project-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* CAROUSEL */
	.carousel {
		position: relative;
		width: 100%;
		height: 100%;
	}

	.carousel-inner {
		position: relative;
		width: 100%;
		height: 100%;
	}

	.carousel-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		position: absolute;
		top: 0;
		left: 0;
		opacity: 0;
		transition: opacity 0.4s ease;
	}

	.carousel-image.active {
		opacity: 1;
		position: relative;
	}

	.carousel-dots {
		position: absolute;
		bottom: 0.75rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0.4rem;
	}

	.carousel-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		border: 1px solid var(--text-dim);
		background: transparent;
		cursor: pointer;
		padding: 0;
		transition: background 0.2s;
	}

	.carousel-dot.active {
		background: var(--accent);
		border-color: var(--accent);
	}

	/* PROJECT INFO */
	.project-info h3 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
	}

	.project-info h3 a {
		color: var(--text-main);
		text-decoration: none;
		transition: color 0.15s;
	}

	.project-info h3 a:hover {
		color: var(--accent);
	}

	.project-info p {
		color: var(--text-dim);
		font-size: 0.9rem;
		line-height: 1.6;
		margin-bottom: 0.75rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.tag {
		font-size: 0.7rem;
		color: var(--text-dim);
	}

	.tag:not(:last-child)::after {
		content: '·';
		margin-left: 0.4rem;
	}
</style>
