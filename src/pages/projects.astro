---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import MainNav from '../components/MainNav.astro';
import PageHeader from '../components/PageHeader.astro';
import { SITE_TITLE } from '../consts';

const labArtifacts = [
	{
		id: 1,
		title: 'MyDanceDNA',
		status: 'Directory platform',
		description: 'A search surface for dancers to find schools, instructors, and courses by style, location, or price.',
		link: 'https://www.mydancedna.com',
		image: '/projects/mydancedna/hero.png',
		screenshots: [
			'/projects/mydancedna/hero.png',
			'/projects/mydancedna/Xnapper-2025-12-28-16.45.33.png',
			'/projects/mydancedna/Xnapper-2025-12-28-16.45.53.png'
		],
		tags: ['PYTHON', 'FASTAPI', 'REACT', 'POSTGRESQL']
	},
	{
		id: 2,
		title: 'No Noise Letter',
		status: 'Signal extraction experiment',
		description: 'Source-aware private briefings: set the topics once, then get a calm newsletter with the useful signal cut out of the feed noise.',
		link: 'https://nonoiseletter.com',
		image: '/projects/nonoiseletter/hero.png',
		screenshots: [
			'/projects/nonoiseletter/hero.png',
			'/projects/nonoiseletter/how-it-works.png',
			'/projects/nonoiseletter/pricing.png'
		],
		tags: ['TYPESCRIPT', 'REACT', 'FASTIFY', 'AI']
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Projects // ${SITE_TITLE}`}
			description="Lab artifacts and shipped experiments by Kuba Szwajka"
		/>
	</head>
	<body>
		<div class="wrapper">
			<MainNav />

			<main class="content-area">
				<PageHeader
					eyebrow="LAB ARTIFACTS"
					title="Projects"
					description="Things I shipped, tested, or used as a workbench. Not every artifact is a polished case study; the point is to show traces of building."
				/>

				{labArtifacts.map((item) => (
					<article class="project">
						<div class="project-image-container">
							{item.screenshots && item.screenshots.length > 0 ? (
								<div class="carousel" data-carousel={`carousel-${item.id}`}>
									<div class="carousel-inner">
										{item.screenshots.map((screenshot, index) => (
											<img
												src={screenshot}
												alt={`${item.title} screenshot ${index + 1}`}
												class={`carousel-image ${index === 0 ? 'active' : ''}`}
												loading={index === 0 ? 'eager' : 'lazy'}
											/>
										))}
									</div>
									{item.screenshots.length > 1 && (
										<div class="carousel-dots" aria-label={`${item.title} screenshots`}>
											{item.screenshots.map((_, index) => (
												<button
													class={`carousel-dot ${index === 0 ? 'active' : ''}`}
													data-index={index}
													aria-label={`View ${item.title} screenshot ${index + 1}`}
													aria-pressed={index === 0 ? 'true' : 'false'}
												></button>
											))}
										</div>
									)}
								</div>
							) : item.image ? (
								<img src={item.image} alt={item.title} class="project-image" />
							) : (
								<div class="project-image-placeholder">
									<span>// {item.title}</span>
								</div>
							)}
						</div>

						<div class="project-info">
							<p class="project-status">{item.status}</p>
							<h2>
								{item.link ? (
									<a href={item.link} target={item.link.startsWith('http') ? '_blank' : '_self'} rel="noopener noreferrer">{item.title} →</a>
								) : (
									item.title
								)}
							</h2>
							<p>{item.description}</p>
							<div class="tags" aria-label={`${item.title} stack`}>
								{item.tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
						</div>
					</article>
				))}
			</main>

			<Footer />
		</div>

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const carousels = document.querySelectorAll('.carousel');
				carousels.forEach((carousel) => {
					const images = carousel.querySelectorAll('.carousel-image');
					const dots = carousel.querySelectorAll('.carousel-dot');
					if (images.length <= 1) return;
					let currentIndex = 0;
					dots.forEach((dot, index) => {
						dot.addEventListener('click', () => {
							images[currentIndex].classList.remove('active');
							dots[currentIndex].classList.remove('active');
							dots[currentIndex].setAttribute('aria-pressed', 'false');
							currentIndex = index;
							images[currentIndex].classList.add('active');
							dots[currentIndex].classList.add('active');
							dots[currentIndex].setAttribute('aria-pressed', 'true');
						});
					});
				});
			});
		</script>
	</body>
</html>

<style>
	.content-area {
		padding: 2rem;
		max-width: 900px;
		margin: 0 auto;
	}

	.project-status {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--text-dim);
		margin-bottom: 0.5rem;
	}

	.project {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(260px, 0.85fr);
		gap: 1.5rem;
		padding: 1rem;
		margin-bottom: 1.5rem;
		border: 1px solid var(--border-color);
		background: color-mix(in srgb, var(--bg-panel) 38%, transparent);
	}

	.project-image-container {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		border: 1px solid var(--border-color);
		background: var(--bg-panel);
	}

	.project-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.project-image-placeholder {
		width: 100%;
		height: 100%;
		background: var(--bg-panel);
		border: 1px dashed var(--border-color);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.85rem;
		color: var(--text-dim);
		font-family: 'JetBrains Mono', monospace;
	}

	.carousel,
	.carousel-inner {
		position: relative;
		width: 100%;
		height: 100%;
	}

	.carousel-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		position: absolute;
		top: 0;
		left: 0;
		opacity: 0;
		transition: opacity 0.25s ease;
	}

	.carousel-image.active {
		opacity: 1;
		position: relative;
	}

	.carousel-dots {
		position: absolute;
		bottom: 0.75rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0.5rem;
		padding: 0.4rem;
		background: color-mix(in srgb, var(--bg-color) 78%, transparent);
		border: 1px solid var(--border-color);
	}

	.carousel-dot {
		width: 10px;
		height: 10px;
		border: 1px solid var(--text-dim);
		background: transparent;
		cursor: pointer;
		padding: 0;
	}

	.carousel-dot.active {
		background: var(--accent);
		border-color: var(--accent);
	}

	.project-info {
		align-self: center;
	}

	.project-info h2 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.35rem;
		margin-bottom: 0.75rem;
	}

	.project-info h2 a {
		color: var(--text-main);
		text-decoration: none;
		transition: color 0.15s;
	}

	.project-info h2 a:hover,
	.project-info h2 a:focus-visible {
		color: var(--accent);
		text-decoration: none;
	}

	.project-info p:not(.project-status) {
		color: var(--text-dim);
		font-size: 0.9rem;
		line-height: 1.7;
		margin-bottom: 1rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tag {
		padding: 0.15rem 0.35rem;
		border: 1px solid var(--border-color);
		font-size: 0.68rem;
		color: var(--text-dim);
		background: var(--bg-color);
	}

	@media (max-width: 760px) {
		.content-area {
			padding: 1.5rem 1rem;
		}

		.project {
			grid-template-columns: 1fr;
		}
	}
</style>
