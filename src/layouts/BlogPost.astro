---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import MainNav from '../components/MainNav.astro';

type TocHeading = {
	depth: number;
	slug: string;
	text: string;
};

type Props = CollectionEntry<'blog'>['data'] & { id: string; headings?: TocHeading[] };

const { title, description, pubDate, updatedDate, tags, id, headings = [] } = Astro.props;
const ogImage = `/og/${id}.png`;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);

// Format date for display
function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		day: '2-digit',
		month: 'short',
		year: 'numeric'
	}).toUpperCase().replace(',', '');
}
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} ogImage={ogImage} />
	</head>

	<body>
		<div class="wrapper">
			<MainNav />

			<article class="blog-post">
				<header class="post-header">
					<span class="date">{formatDate(pubDate)}</span>
					<h1>{title}</h1>
					<div class="post-actions">
						<a href={`/blog/${id}.txt`} class="raw-link" target="_blank" rel="noopener noreferrer">Raw text for LLM</a>
					</div>
				</header>

				{tocHeadings.length > 0 && (
					<nav class="toc" aria-label="Table of contents">
						<p class="toc-title">Contents</p>
						<ol>
							{tocHeadings.map((heading) => (
								<li class={`toc-depth-${heading.depth}`}>
									<a href={`#${heading.slug}`} data-toc-link={heading.slug}>{heading.text}</a>
								</li>
							))}
						</ol>
					</nav>
				)}

				<div class="prose">
					<slot />
				</div>

				<footer class="post-footer">
					<a href="/" class="btn-arrow">&lt;- All Posts</a>
					<a href={`https://github.com/JakubSzwajka/JakubSzwajka.github.io/edit/main/src/content/blog/${id}.md`} class="btn-arrow" target="_blank" rel="noopener noreferrer">Edit on GitHub -&gt;</a>
				</footer>
			</article>

			<Footer />
		</div>

		<script>
			const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
			const headings = tocLinks
				.map((link) => document.getElementById(link.getAttribute('data-toc-link') || ''))
				.filter(Boolean);

			function activateTocLink() {
				if (tocLinks.length === 0 || headings.length === 0) return;

				const currentHeading = [...headings]
					.reverse()
					.find((heading) => heading.getBoundingClientRect().top <= 140) || headings[0];

				tocLinks.forEach((link) => {
					link.classList.toggle('is-active', link.getAttribute('data-toc-link') === currentHeading.id);
				});
			}

			activateTocLink();
			document.addEventListener('scroll', activateTocLink, { passive: true });
			window.addEventListener('resize', activateTocLink);
		</script>
	</body>
</html>

<style>
	.blog-post {
		/* Container styles handled by wrapper */
	}

	.post-header {
		padding: 2rem;
		max-width: 800px;
		margin: 0 auto;
	}

	.date {
		font-size: 0.8rem;
		color: var(--text-dim);
		display: block;
		margin-bottom: 0.5rem;
	}

	.post-header h1 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.5rem;
		line-height: 1.2;
		margin: 0;
	}

	.post-actions {
		margin-top: 1rem;
	}

	.raw-link {
		display: inline-flex;
		align-items: center;
		padding: 0.35rem 0.6rem;
		border: 1px solid var(--accent);
		color: var(--accent);
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		text-decoration: none;
	}

	.raw-link:hover {
		background: var(--accent);
		color: var(--bg-color);
		text-decoration: none;
	}

	.toc {
		position: fixed;
		top: 7rem;
		left: calc(50% + 430px);
		width: 280px;
		max-height: calc(100vh - 9rem);
		overflow-y: auto;
		padding: 1rem;
		background: color-mix(in srgb, var(--bg-color) 92%, transparent);
		backdrop-filter: blur(8px);
		font-size: 0.75rem;
		z-index: 10;
	}

	.toc-title {
		margin: 0 0 0.75rem;
		font-family: 'Space Grotesk', sans-serif;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-main);
	}

	.toc ol {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.toc li {
		margin-bottom: 0.55rem;
		line-height: 1.35;
	}

	.toc .toc-depth-3 {
		padding-left: 0.8rem;
	}

	.toc a {
		color: var(--text-dim);
		text-decoration: none;
	}

	.toc a:hover,
	.toc a.is-active {
		color: var(--accent);
		text-decoration: none;
	}

	.toc a.is-active {
		font-weight: 700;
	}

	/* Prose content styling */
	.prose {
		padding: 2rem;
		max-width: 800px;
		margin: 0 auto;
	}

	/* Global prose styles */
	.prose :global(h2) {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.75rem;
		margin-top: 3rem;
		margin-bottom: 1rem;
		color: var(--text-main);
	}

	.prose :global(h3) {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.4rem;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
		color: var(--text-main);
	}

	.prose :global(p) {
		color: var(--text-dim);
		margin-bottom: 1.5rem;
		line-height: 1.8;
	}

	.prose :global(a) {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.prose :global(a:hover) {
		text-decoration: none;
	}

	.prose :global(strong) {
		color: var(--text-main);
		font-weight: 700;
	}

	.prose :global(ul),
	.prose :global(ol) {
		color: var(--text-dim);
		margin-bottom: 1.5rem;
		padding-left: 1.5rem;
	}

	.prose :global(li) {
		margin-bottom: 0.5rem;
	}

	.prose :global(blockquote) {
		border-left: 4px solid var(--accent);
		padding-left: 1.5rem;
		margin: 2rem 0;
		color: var(--text-dim);
		font-style: italic;
	}

	.prose :global(pre) {
		background: var(--bg-panel);
		border: 1px solid var(--border-color);
		padding: 1.5rem;
		overflow-x: auto;
		margin: 2rem 0;
		font-size: 0.9rem;
	}

	.prose :global(code) {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.9em;
	}

	.prose :global(p code),
	.prose :global(li code) {
		background: var(--bg-panel);
		border: 1px solid var(--border-color);
		padding: 0.1rem 0.4rem;
		border-radius: 2px;
	}

	.prose :global(hr) {
		border: none;
		border-top: 1px dashed var(--border-color);
		margin: 3rem 0;
	}

	.prose :global(img) {
		max-width: 100%;
		height: auto;
		margin: 2rem 0;
		border: 1px solid var(--border-color);
	}

	.prose :global(video) {
		max-width: 100%;
		margin: 2rem 0;
		border: 1px solid var(--border-color);
	}

	.post-footer {
		padding: 2rem;
		border-top: 1px solid var(--border-color);
		display: flex;
		justify-content: space-between;
		max-width: 800px;
		margin: 0 auto;
	}

	@media (max-width: 1450px) {
		.toc {
			display: none;
		}
	}

	@media (min-width: 900px) {
		.post-footer {
			padding: 2rem 4rem;
		}
	}

	.btn-arrow {
		color: var(--accent);
		text-decoration: none;
		font-weight: 700;
		text-transform: uppercase;
		font-size: 0.9rem;
		border-bottom: 2px solid transparent;
		transition: border-color 0.2s;
	}

	.btn-arrow:hover {
		border-bottom: 2px solid var(--accent);
	}
</style>
