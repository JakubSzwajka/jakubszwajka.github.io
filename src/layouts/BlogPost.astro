---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import MainNav from '../components/MainNav.astro';

type TocHeading = {
	depth: number;
	slug: string;
	text: string;
};

type Props = CollectionEntry<'blog'>['data'] & { id: string; headings?: TocHeading[] };

const { title, description, pubDate, updatedDate, tags, id, headings = [] } = Astro.props;
const ogImage = `/og/${id}.png`;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);

function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		day: '2-digit',
		month: 'short',
		year: 'numeric',
	}).toUpperCase().replace(',', '');
}
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} ogImage={ogImage} />
	</head>

	<body>
		<div class="lab-page post-page">
			<MainNav />

			<main class={`post-shell ${tocHeadings.length === 0 ? 'post-shell--no-toc' : ''}`}>
				{tocHeadings.length > 0 && (
					<nav class="toc" aria-label="Table of contents">
						<p class="toc-title">Contents</p>
						<ol>
							{tocHeadings.map((heading) => (
								<li class={`toc-depth-${heading.depth}`}>
									<a href={`#${heading.slug}`} data-toc-link={heading.slug}>{heading.text}</a>
								</li>
							))}
						</ol>
					</nav>
				)}

				<article class="blog-post">
					<header class="post-header">
						<div class="post-header__meta-row">
							<p class="lab-eyebrow">Lab note</p>
							<p class="post-header__date">{formatDate(pubDate)}</p>
						</div>
						<h1>{title}</h1>
						{(tags?.length || updatedDate) && (
							<div class="post-meta-strip">
								{tags?.map((tag) => <span class="lab-chip">{tag.toUpperCase()}</span>)}
								{updatedDate && <span class="updated">Updated {formatDate(updatedDate)}</span>}
							</div>
						)}
						<div class="post-actions-inline" aria-label="Post actions">
							<a href={`/blog/${id}.txt`} target="_blank" rel="noopener noreferrer">Raw text for LLM</a>
							<a href="/">All posts</a>
							<a href={`https://github.com/JakubSzwajka/JakubSzwajka.github.io/edit/main/src/content/blog/${id}.md`} target="_blank" rel="noopener noreferrer">Edit on GitHub</a>
						</div>
					</header>

					<div class="prose">
						<slot />
					</div>
				</article>

				<aside class="post-side" aria-label="Post actions">
					<span class="lab-label">Actions</span>
					<a href={`/blog/${id}.txt`} target="_blank" rel="noopener noreferrer">Raw text for LLM</a>
					<a href="/">All posts</a>
					<a href={`https://github.com/JakubSzwajka/JakubSzwajka.github.io/edit/main/src/content/blog/${id}.md`} target="_blank" rel="noopener noreferrer">Edit on GitHub</a>
				</aside>
			</main>

			<footer class="post-footer-bar">
				<div class="post-footer-inner">
					<a href="/" class="btn-arrow">&lt;- All Posts</a>
					<a href={`https://github.com/JakubSzwajka/JakubSzwajka.github.io/edit/main/src/content/blog/${id}.md`} class="btn-arrow" target="_blank" rel="noopener noreferrer">Edit on GitHub -&gt;</a>
				</div>
			</footer>

			<Footer />
		</div>

		<script>
			const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
			const headings = tocLinks
				.map((link) => document.getElementById(link.getAttribute('data-toc-link') || ''))
				.filter(Boolean);

			function activateTocLink() {
				if (tocLinks.length === 0 || headings.length === 0) return;

				const currentHeading = [...headings]
					.reverse()
					.find((heading) => heading.getBoundingClientRect().top <= 140) || headings[0];

				tocLinks.forEach((link) => {
					link.classList.toggle('is-active', link.getAttribute('data-toc-link') === currentHeading.id);
				});
			}

			activateTocLink();
			document.addEventListener('scroll', activateTocLink, { passive: true });
			window.addEventListener('resize', activateTocLink);
		</script>
	</body>
</html>

<style>
	.post-shell {
		width: min(100% - 3rem, 1360px);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 220px minmax(0, 820px) minmax(180px, 1fr);
		gap: 3rem;
		align-items: start;
		padding: 3.5rem 0 0;
	}

	.post-shell--no-toc {
		grid-template-columns: minmax(0, 820px) minmax(180px, 1fr);
	}

	.blog-post {
		min-width: 0;
		max-width: 820px;
	}

	.post-header {
		padding-bottom: 2rem;
		margin-bottom: 2.75rem;
		border-bottom: 1px solid var(--border-color);
	}

	.post-header__meta-row {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
		font-size: 0.75rem;
		text-transform: uppercase;
	}

	.post-header__meta-row p {
		margin: 0;
	}

	.post-header__date {
		color: var(--text-dim);
	}

	.post-header h1 {
		font-size: 4.75rem;
		line-height: 0.95;
		letter-spacing: 0;
		margin: 0;
	}

	.post-meta-strip {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.45rem;
		margin-top: 1.25rem;
	}

	.post-actions-inline {
		display: none;
	}

	.updated {
		color: var(--text-dim);
		font-size: 0.72rem;
		text-transform: uppercase;
	}

	.toc,
	.post-side {
		position: sticky;
		top: 5.5rem;
		align-self: start;
		color: var(--text-dim);
		font-size: 0.76rem;
	}

	.toc {
		border-left: 1px solid var(--border-color);
		padding-left: 1rem;
		padding-right: 0.5rem;
		max-height: calc(100vh - 9rem);
		overflow: auto;
	}

	.toc-title {
		margin: 0 0 0.9rem;
		color: var(--text-main);
		font-family: 'Space Grotesk', sans-serif;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.toc ol {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.toc li {
		margin-bottom: 0.7rem;
		line-height: 1.35;
	}

	.toc .toc-depth-3 {
		padding-left: 0.8rem;
	}

	.toc a,
	.post-side a {
		color: var(--text-dim);
		text-decoration: none;
	}

	.toc a:hover,
	.toc a:focus-visible,
	.toc a.is-active,
	.post-side a:hover,
	.post-side a:focus-visible {
		color: var(--accent);
		text-decoration: none;
	}

	.toc a.is-active {
		font-weight: 700;
	}

	.post-side {
		border-top: 1px solid var(--border-color);
		padding-top: 0.9rem;
	}

	.post-side .lab-label {
		display: block;
		margin-bottom: 0.6rem;
	}

	.post-side a {
		display: block;
		border-bottom: 1px solid var(--border-color);
		padding: 0.65rem 0;
	}

	.prose {
		max-width: 820px;
		margin: 0;
	}

	.prose :global(h2) {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.85rem;
		line-height: 1.15;
		margin-top: 3.6rem;
		margin-bottom: 1rem;
		padding-top: 1.3rem;
		border-top: 1px solid var(--border-color);
		color: var(--text-main);
	}

	.prose :global(h3) {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.35rem;
		margin-top: 2rem;
		margin-bottom: 1rem;
		color: var(--text-main);
	}

	.prose :global(p) {
		color: var(--text-dim);
		margin-bottom: 1.55rem;
		line-height: 1.78;
	}

	.prose :global(a) {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.prose :global(a:hover) {
		text-decoration: none;
	}

	.prose :global(strong) {
		color: var(--text-main);
		font-weight: 700;
	}

	.prose :global(em) {
		color: var(--text-main);
	}

	.prose :global(ul),
	.prose :global(ol) {
		color: var(--text-dim);
		margin-bottom: 1.7rem;
		padding-left: 1.5rem;
	}

	.prose :global(li) {
		margin-bottom: 0.5rem;
	}

	.prose :global(blockquote) {
		border-left: 4px solid var(--accent);
		padding-left: 1.5rem;
		margin: 2rem 0;
		color: var(--text-dim);
		font-style: italic;
	}

	.prose :global(pre) {
		background: var(--bg-panel);
		border: 1px solid var(--border-color);
		padding: 1.25rem;
		overflow-x: auto;
		margin: 2rem 0;
		font-size: 0.82rem;
		line-height: 1.55;
	}

	.prose :global(code) {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.9em;
	}

	.prose :global(p code),
	.prose :global(li code) {
		background: var(--bg-panel);
		border: 1px solid var(--border-color);
		padding: 0.1rem 0.4rem;
		border-radius: 2px;
	}

	.prose :global(hr) {
		border: none;
		border-top: 1px dashed var(--border-color);
		margin: 3rem 0;
	}

	.prose :global(img) {
		max-width: 100%;
		height: auto;
		margin: 2rem 0;
		border: 1px solid var(--border-color);
	}

	.prose :global(video) {
		max-width: 100%;
		margin: 2rem 0;
		border: 1px solid var(--border-color);
	}

	.post-footer-bar {
		width: 100%;
		border-top: 1px solid var(--border-color);
		background: var(--bg-color);
		margin-top: 4rem;
	}

	.post-footer-inner {
		width: min(100% - 3rem, 1360px);
		margin: 0 auto;
		padding: 2rem 0;
		display: flex;
		justify-content: space-between;
		gap: 1rem;
	}

	.btn-arrow {
		color: var(--accent);
		text-decoration: none;
		font-weight: 700;
		text-transform: uppercase;
		font-size: 0.9rem;
		border-bottom: 2px solid transparent;
		transition: border-color 0.2s;
	}

	.btn-arrow:hover,
	.btn-arrow:focus-visible {
		border-bottom-color: var(--accent);
		text-decoration: none;
	}

	@media (max-width: 1120px) {
		.post-shell,
		.post-shell--no-toc {
			display: block;
			width: min(100% - 3rem, 820px);
		}

		.blog-post {
			max-width: 820px;
			margin: 0 auto;
		}

		.post-header h1 {
			font-size: 3.6rem;
		}

		.toc {
			display: none;
		}

		.post-actions-inline {
			display: flex;
			flex-wrap: wrap;
			gap: 0.65rem;
			margin-top: 1.2rem;
		}

		.post-actions-inline a {
			border: 1px solid var(--border-color);
			color: var(--text-main);
			font-family: 'Space Grotesk', sans-serif;
			font-size: 0.72rem;
			font-weight: 700;
			letter-spacing: 0;
			padding: 0.55rem 0.65rem;
			text-decoration: none;
			text-transform: uppercase;
		}

		.post-actions-inline a:hover,
		.post-actions-inline a:focus-visible {
			background: var(--accent);
			border-color: var(--accent);
			color: var(--bg-color);
			text-decoration: none;
		}

		.post-side {
			display: none;
		}
	}

	@media (max-width: 640px) {
		.post-shell,
		.post-shell--no-toc,
		.post-footer-inner {
			width: min(100% - 2rem, 820px);
		}

		.post-shell {
			padding-top: 2.7rem;
		}

		.post-header__meta-row {
			display: block;
		}

		.post-header__date {
			margin-top: 0.35rem !important;
		}

		.post-header h1 {
			font-size: 2.55rem;
		}

		.prose :global(h2) {
			font-size: 1.55rem;
			margin-top: 2.5rem;
		}

		.prose :global(h3) {
			font-size: 1.25rem;
		}

		.prose :global(p) {
			line-height: 1.75;
		}

		.post-footer-inner {
			flex-direction: column;
		}
	}
</style>
