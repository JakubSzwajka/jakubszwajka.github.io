---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	ogImage?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, ogImage } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Google Fonts: JetBrains Mono + Space Grotesk -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Space+Grotesk:wght@400;600;700&display=swap" rel="stylesheet" />

<!-- Phosphor Icons -->
<script src="https://unpkg.com/@phosphor-icons/web"></script>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
{ogImage && <meta property="twitter:image" content={new URL(ogImage, Astro.site)} />}

<!-- Structured Data (JSON-LD) -->
<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Kuba Szwajka",
  "alternateName": "Jakub Szwajka",
  "url": "https://kubaszwajka.com",
  "jobTitle": "Software Architect",
  "description": "Software Architect based in Wrocław, Poland. Specializing in EdTech, FinTech, and modular architecture.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Wroclaw",
    "addressCountry": "Poland"
  },
  "email": "szwajkajakub@gmail.com",
  "sameAs": [
    "https://github.com/JakubSzwajka",
    "https://www.linkedin.com/in/jakub-szwajka/",
    "https://medium.com/@szwajkajakub"
  ]
}
</script>

<!-- Google Analytics -->
{import.meta.env.PUBLIC_GA_ID && import.meta.env.PROD && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`}></script>
    <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  </>
)}

<!-- Umami Analytics -->
{import.meta.env.PROD && (
  <script
    defer
    src="https://umami.infra.niuluc.me/script.js"
    data-website-id="e8119e14-bc31-4edd-a61b-0c1864fe5438"
  />
)}

<script is:inline>
(() => {
  const MAX_VALUE_LENGTH = 80;
  const ANALYTICS_PREFIX = 'analytics';
  const IGNORED_DATA_KEYS = new Set(['analyticsArea', 'analyticsEvent', 'analyticsTracked']);

  const cleanValue = (value) => {
    if (!value) return undefined;
    const cleaned = String(value).replace(/\s+/g, ' ').trim();
    return cleaned ? cleaned.slice(0, MAX_VALUE_LENGTH) : undefined;
  };

  const camelToSnake = (value) => value.replace(/[A-Z]/g, (letter) => `_${letter.toLowerCase()}`);

  const getDatasetProps = (link) => Object.entries(link.dataset).reduce((props, [key, value]) => {
    if (!key.startsWith(ANALYTICS_PREFIX) || IGNORED_DATA_KEYS.has(key)) return props;

    const propName = camelToSnake(
      key.replace(ANALYTICS_PREFIX, '').replace(/^./, (letter) => letter.toLowerCase())
    );
    const propValue = cleanValue(value);
    if (propName && propValue) props[propName] = propValue;

    return props;
  }, {});

  const inferArea = (link) => {
    const explicitArea = link.getAttribute('data-analytics-area') ||
      link.closest('[data-analytics-area]')?.getAttribute('data-analytics-area');

    if (explicitArea) return explicitArea;
    if (link.closest('.main-nav')) return 'main_nav';
    if (link.closest('.resume-links')) return 'resume_links';
    if (link.closest('.artifact-list')) return 'projects';
    if (link.closest('.post-actions-inline')) return 'post_header_actions';
    if (link.closest('.post-side')) return 'post_side_actions';
    if (link.closest('.post-footer-bar')) return 'post_footer_actions';
    if (link.closest('.prose')) return 'article_body';

    return 'page';
  };

  const getLinkLabel = (link) => cleanValue(
    link.getAttribute('data-analytics-label') ||
    link.getAttribute('aria-label') ||
    link.textContent
  );

  const getUrl = (href) => {
    try {
      return new URL(href, window.location.href);
    } catch {
      return null;
    }
  };

  const getDestinationProps = (url) => {
    if (!url) return {};

    if (url.protocol === 'mailto:') {
      return { contact_type: 'email' };
    }

    if (!['http:', 'https:'].includes(url.protocol)) return {};

    return {
      destination_host: cleanValue(url.hostname.replace(/^www\./, '')),
      destination_path: cleanValue(url.pathname),
    };
  };

  const getEvent = (link) => {
    const explicitEvent = link.getAttribute('data-analytics-event');
    if (explicitEvent) return cleanValue(explicitEvent);

    const url = getUrl(link.getAttribute('href'));
    if (!url || url.origin === window.location.origin) return null;

    if (url.protocol === 'mailto:') return 'contact_click';
    if (['http:', 'https:'].includes(url.protocol)) return 'outbound_link_click';

    return null;
  };

  const track = (eventName, props) => {
    if (!eventName || !window.umami || typeof window.umami.track !== 'function') return;

    window.umami.track(eventName, {
      ...props,
      page_path: cleanValue(window.location.pathname),
    });
  };

  document.addEventListener('click', (event) => {
    const target = event.target instanceof Element ? event.target : null;
    const link = target?.closest('a[href]');

    if (!link || link.getAttribute('data-analytics-tracked') === 'false') return;

    const eventName = getEvent(link);
    if (!eventName) return;

    const url = getUrl(link.getAttribute('href'));

    track(eventName, {
      ...getDestinationProps(url),
      ...getDatasetProps(link),
      link_area: cleanValue(inferArea(link)),
      link_label: getLinkLabel(link),
    });
  }, { capture: true });
})();
</script>

<!-- Plausible Analytics -->
{import.meta.env.PROD && (
  <>
    <script async src="https://plausible.app.kubaszwajka.com/js/pa-JdKjPX8bWZvD1MBLKFgv_.js"></script>
    <script is:inline>
      window.plausible = window.plausible || function(){(plausible.q = plausible.q || []).push(arguments)};
      plausible.init = plausible.init || function(i){plausible.o = i || {}};
      plausible.init();
    </script>
  </>
)}
