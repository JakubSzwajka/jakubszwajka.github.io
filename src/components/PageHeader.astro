---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	meta?: string;
	class?: string;
}

const { eyebrow, title, description, meta, class: className = '' } = Astro.props;
---

<header class={`page-header ${className}`}>
	{meta && <p class="page-header__meta">{meta}</p>}
	{eyebrow && <p class="page-header__eyebrow">{eyebrow}</p>}
	<h1>{title}</h1>
	{description && <p class="page-header__description">{description}</p>}
	<slot name="actions" />
</header>

<style>
	.page-header {
		padding-bottom: 1.5rem;
		margin-bottom: 2rem;
		border-bottom: 1px solid var(--border-color);
	}

	.page-header__meta {
		font-size: 0.8rem;
		color: var(--text-dim);
		display: block;
		margin-bottom: 0.5rem;
	}

	.page-header__eyebrow {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 0.5rem;
	}

	.page-header h1 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: clamp(2rem, 6vw, 3.5rem);
		line-height: 1;
		letter-spacing: -0.04em;
		margin: 0;
	}

	.page-header__description {
		max-width: 720px;
		color: var(--text-dim);
		font-size: 0.95rem;
		line-height: 1.7;
		margin: 1rem 0 0;
	}
</style>
