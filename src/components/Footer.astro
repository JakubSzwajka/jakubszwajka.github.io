---
const today = new Date();
---

<footer class="footer-strip">
	<div class="footer-strip__inner">
		<div>&copy; {today.getFullYear()} KUBA SZWAJKA</div>
		<div>
			<i class="ph-fill ph-lightning" style="color: var(--accent)"></i> POWERED BY AI & CAFFEINE
		</div>
	</div>
</footer>

<style>
	.footer-strip {
		border-top: 1px solid var(--border-color);
		padding: 0;
	}

	.footer-strip__inner {
		width: min(100% - 3rem, 1360px);
		margin: 0 auto;
		padding: 2rem 0;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.8rem;
		color: var(--text-dim);
		text-transform: uppercase;
	}

	@media (max-width: 600px) {
		.footer-strip__inner {
			width: min(100% - 2rem, 1360px);
			padding: 1.5rem 0;
			flex-direction: column;
			gap: 0.5rem;
			text-align: center;
		}
	}
</style>
