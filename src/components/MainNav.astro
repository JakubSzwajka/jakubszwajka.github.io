---
import { GITHUB_URL, LINKEDIN_URL, TWITTER_URL, EMAIL } from '../consts';
const currentPath = Astro.url.pathname;
---

<nav class="main-nav">
	<a href="/" class="nav-brand">Kuba Szwajka</a>
	<div class="nav-right">
		<div class="nav-links">
			<a href="/" class={`nav-item ${currentPath === '/' ? 'active' : ''}`}>
				Home
			</a>
			<a href="/projects" class={`nav-item ${currentPath === '/projects' ? 'active' : ''}`}>
				Projects
			</a>
			<a href="/lucy" class={`nav-item ${currentPath === '/lucy' ? 'active' : ''}`}>
				Lucy
			</a>
			<a href="/resume" class={`nav-item ${currentPath === '/resume' ? 'active' : ''}`}>
				Resume
			</a>
		</div>
		<span class="nav-divider">|</span>
		<div class="nav-socials">
			<a href={GITHUB_URL} class="nav-social" target="_blank" aria-label="GitHub">
				<i class="ph-bold ph-github-logo"></i>
			</a>
			<a href={LINKEDIN_URL} class="nav-social" target="_blank" aria-label="LinkedIn">
				<i class="ph-bold ph-linkedin-logo"></i>
			</a>
			<a href={TWITTER_URL} class="nav-social" target="_blank" aria-label="X">
				<i class="ph-bold ph-x-logo"></i>
			</a>
			<a href={`mailto:${EMAIL}`} class="nav-social" aria-label="Email">
				<i class="ph-bold ph-envelope-simple"></i>
			</a>
		</div>
	</div>
</nav>

<style>
	.main-nav {
		border-bottom: 1px solid rgba(255, 255, 255, 0.12);
		padding: 1.5rem 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		width: 100vw;
		position: relative;
		left: 50%;
		transform: translateX(-50%);
	}

	@media (min-width: 900px) {
		.main-nav {
			padding: 1.5rem 4rem;
		}
	}

	.nav-brand {
		text-decoration: none;
		color: var(--accent);
		font-weight: 700;
		font-size: 1.1rem;
		white-space: nowrap;
	}

	.nav-brand:hover {
		text-decoration: none;
		color: var(--accent);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.nav-links {
		display: flex;
		gap: 2rem;
	}

	.nav-divider {
		color: rgba(255, 255, 255, 0.2);
		font-weight: 300;
		user-select: none;
	}

	.nav-socials {
		display: flex;
		gap: 2rem;
		font-size: 0.85rem;
	}

	.nav-social {
		text-decoration: none;
		color: var(--text-dim);
		transition: color 0.2s;
		white-space: nowrap;
	}

	.nav-social:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.nav-social i {
		margin-right: 4px;
	}

	.nav-item {
		text-decoration: none;
		color: var(--text-dim);
		transition: color 0.2s;
		position: relative;
		font-weight: 600;
		font-size: 0.85rem;
	}

	.nav-item:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.nav-item.active {
		color: var(--accent);
	}

	.nav-item.active::after {
		content: '';
		position: absolute;
		bottom: -1.5rem;
		left: 0;
		right: 0;
		height: 2px;
		background: var(--accent);
	}

	@media (max-width: 600px) {
		.main-nav {
			padding: 1rem;
			font-size: 0.85rem;
		}

		.nav-links {
			gap: 1.5rem;
		}

		.nav-socials {
			display: none;
		}

		.nav-divider {
			display: none;
		}
	}
</style>
